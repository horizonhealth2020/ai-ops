# ──────────────────────────────────────────────────────────────────
# AI Ops Backend — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# Database (PgBouncer for app queries, direct for migrations)
PGBOUNCER_URL=postgresql://user:password@host:6432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis
REDIS_URL=redis://default:password@host:6379

# Vapi
VAPI_API_KEY=your_vapi_api_key_here

# OpenAI (LLM proxy)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Stripe (platform account)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (platform account)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Clerk (dashboard auth)
CLERK_SECRET_KEY=sk_test_...

# n8n (async post-call processing)
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook

# Encryption (32-byte hex for AES-256)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# App
PORT=3000
NODE_ENV=development
DB_SSL=false
